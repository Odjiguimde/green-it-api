# ============================================================
# FICHIER .env — Variables d'environnement sensibles
# NE JAMAIS commiter ce fichier dans Git (.gitignore)
# ============================================================

# URI de connexion MongoDB Atlas
# Remplacez <username>, <password> et <cluster> par vos vraies valeurs
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Nom de la base de données
DB_NAME=green_it_db

# Port du serveur Flask (optionnel, 5000 par défaut)
FLASK_PORT=5000

# Mode debug Flask (True en développement, False en production)
FLASK_DEBUG=True
